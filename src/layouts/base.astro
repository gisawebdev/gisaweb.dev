---
import '../global.css'


const {
  title = 'gisawebdev - web development, technology and tools blog'
} = Astro.props
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<slot/>
	</body>
</html>